import { TaskItem, WindowTile, PopupTile, LayerTile, NotificationToast, TrayIcon } from "types.slint";

// One row of the time report (a category or project).
export struct ReportRow {
    label: string,
    today: string,
    week: string,
}

// One bar of the weekly graph.
export struct DayBar {
    label: string,    // weekday, e.g. "Mon"
    value: string,    // formatted time, e.g. "2h"
    fraction: float,  // 0..1 bar height relative to the busiest day
    selected: bool,   // the currently selected day
}

// Report figures, computed host-side and pushed in when the report opens or the
// selected day/week changes.
export global ReportData {
    in property <string> day-label: "—";    // selected day, e.g. "Thu Jun 19"
    in property <string> week-label: "—";    // selected week range
    in property <string> day-total: "0m";
    in property <string> week-total: "0m";
    in property <[DayBar]> week-bars;
    in property <[ReportRow]> by-category;
    in property <[ReportRow]> by-project;
    // Whether navigating forward is allowed (can't go past today).
    in property <bool> can-forward: false;
}

// Current settings values, pushed in when the settings dialog opens.
export global SettingsData {
    in property <string> terminal;
    in property <string> browser;
    in property <string> categories-csv;
    in property <string> idle-minutes;
}

// Values for the per-task settings dialog. The host pushes the current task's
// values when the dialog opens; the dialog edits the `in-out` ones in place.
export global TaskSettingsData {
    // Id of the task being edited, or -1 when none.
    in property <int> id: -1;
    in-out property <string> name;
    // Index into AppData.categories of the task's category.
    in-out property <int> category-index;
    // Index into `palette` of the selected colour.
    in-out property <int> selected-index;
    // Available colour swatches (resolved host-side from the colour palette).
    in property <[color]> palette;
}

// State the host (Rust) pushes into the UI.
export global AppData {
    in property <[TaskItem]> tasks;
    // Id of the active task, or -1 when none.
    in property <int> active-task: -1;
    // Name of the active task, resolved host-side for the header.
    in property <string> active-name;
    // Windows belonging to the active task (already filtered host-side).
    in property <[WindowTile]> windows;
    // Id of a window the compositor asked to move (client dragged its own
    // title bar → xdg_toplevel.move); the view drives the drag while set, and
    // resets it to -1 on button release. -1 = none.
    in-out property <int> moving-window: -1;
    // Client popups (menus, dropdowns) for the active task's windows.
    in property <[PopupTile]> popups;
    // wlr-layer-shell surfaces (panels, wallpaper, overlays).
    in property <[LayerTile]> layers;
    // On-screen notification toasts.
    in property <[NotificationToast]> notifications;
    // System-tray (StatusNotifierItem) icons.
    in property <[TrayIcon]> tray;
    // Available categories for the wizard's dropdown.
    in property <[string]> categories;
    // Previously entered origin-repo paths, for the wizard's dropdown.
    in property <[string]> repo-history;
    // Command used to label the "Open browser" action, for the tooltip.
    in property <string> browser-name: "browser";
    // Live clock, updated by the host.
    in property <string> clock-time: "--:--";
    in property <string> clock-date: "";
}

// Actions the UI invokes; the host handles them.
export global Logic {
    // Wizard "Create": name, category, branch, repo (branch/repo may be empty).
    callback create-task(string, string, string, string);
    // Sidebar interactions.
    callback switch-task(int /* id */);
    // Switch to desktop 0 (the scratch desktop not tied to any task).
    callback switch-to-desktop0();
    callback delete-task(int /* id */);
    // Reorder: move the task with this id by `delta` (-1 up, +1 down).
    callback move-task(int /* id */, int /* delta */);
    // Per-task settings dialog (host populates TaskSettingsData and opens it).
    callback open-task-settings(int /* id */);
    // Save edited task properties: id, name, category, colour-palette index.
    callback save-task-settings(int /* id */, string /* name */, string /* category */, int /* color-index */);
    // Task header actions.
    callback open-browser();
    callback open-terminal();
    // Launch an arbitrary command line as a client (run dialog / Alt+F2).
    callback run-command(string /* command */);
    // Settings + report (host populates data and toggles the dialog).
    callback open-settings();
    callback save-settings(string /* terminal */, string /* browser */, string /* categories-csv */, string /* idle-minutes */);
    callback open-report();
    // Lock screen (also raised automatically on idle).
    callback lock();
    callback unlock();
    // Dismiss a notification toast.
    callback dismiss-notification(int /* id */);
    // Activate a system-tray item (left click).
    callback tray-activate(string /* id */);
    // Global keyboard shortcuts.
    callback cycle-window(bool /* forward */);
    callback switch-task-index(int /* index */);
    callback close-active-window();
    // Report navigation (changes the selected day; the week follows).
    callback report-prev-day();
    callback report-next-day();
    callback report-prev-week();
    callback report-next-week();
    // Window management / input forwarding.
    callback close-window(int /* id */);
    callback focus-window(int /* id */);
    // Drag the floating window frame by a delta (title-bar drag). Applied
    // incrementally: the host adds the delta to the window's stored position.
    callback move-window(int /* id */, length /* dx */, length /* dy */);
    // Resize the floating window frame by a delta. `edges` is a bitmask of which
    // edges are being dragged: 1=left, 2=right, 4=top, 8=bottom.
    callback resize-window(int /* id */, int /* edges */, length /* dx */, length /* dy */);
    // Toggle a window's minimized / maximized state.
    callback minimize-window(int /* id */);
    callback maximize-window(int /* id */);
    callback pointer-moved(int /* id */, length /* x */, length /* y */);
    callback pointer-button(int /* id */, length /* x */, length /* y */, int /* btn */, bool /* pressed */);
    callback key-event(string /* text */, bool /* ctrl */, bool /* alt */, bool /* shift */, bool /* pressed */);
}
