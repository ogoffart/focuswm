import { Theme } from "theme.slint";
import { AppData, Logic, ReportData, SettingsData, TaskSettingsData, ReportRow } from "globals.slint";
import { TaskItem, WindowTile, PopupTile, LayerTile, NotificationToast, TrayIcon } from "types.slint";
import { Sidebar } from "sidebar.slint";
import { Wizard } from "wizard.slint";
import { Settings } from "settings.slint";
import { TaskSettings } from "task_settings.slint";
import { Launcher } from "launcher.slint";
import { Report } from "report.slint";
import { LockScreen } from "lock.slint";
import { Palette } from "std-widgets.slint";

export { AppData, Logic, ReportData, SettingsData, TaskSettingsData, ReportRow, TaskItem, WindowTile, PopupTile, LayerTile, NotificationToast, TrayIcon, Theme }

// A positioned client surface (popup or layer-shell) rendered as a GL texture,
// forwarding pointer + keyboard to its Wayland surface.
component ClientSurface inherits Rectangle {
    in property <int> id;
    in property <image> texture;

    forward-focus: fs;

    Image {
        source: texture;
        image-fit: fill;
        width: 100%;
        height: 100%;
    }

    fs := FocusScope {
        key-pressed(e) => {
            Logic.key-event(e.text, e.modifiers.control, e.modifiers.alt, e.modifiers.shift, true);
            accept
        }
        key-released(e) => {
            Logic.key-event(e.text, e.modifiers.control, e.modifiers.alt, e.modifiers.shift, false);
            accept
        }
        ta := TouchArea {
            pointer-event(e) => {
                fs.focus();
                if e.kind == PointerEventKind.down {
                    Logic.pointer-button(root.id, ta.mouse-x, ta.mouse-y, root.btn-code(e.button), true);
                } else if e.kind == PointerEventKind.up {
                    Logic.pointer-button(root.id, ta.mouse-x, ta.mouse-y, root.btn-code(e.button), false);
                } else if e.kind == PointerEventKind.move {
                    Logic.pointer-moved(root.id, ta.mouse-x, ta.mouse-y);
                }
            }
        }
    }

    pure function btn-code(b: PointerEventButton) -> int {
        b == PointerEventButton.left ? 1
            : b == PointerEventButton.right ? 2
            : b == PointerEventButton.middle ? 3
            : 0
    }
}

// A thin invisible grip along one or more window edges that resizes the frame.
// `edges` is a bitmask (1=left, 2=right, 4=top, 8=bottom) passed straight to the
// host, which applies the drag delta to the matching sides. The delta is the
// pointer's offset from where the press started; because the host adds it to the
// stored geometry, the grip self-corrects back under the cursor on the next move.
component ResizeHandle inherits TouchArea {
    in property <int> id;
    in property <int> edges;
    // Reports the press/release of a resize so the frame can disable its
    // geometry animation while the user drags a grip (else it rubber-bands).
    callback active(bool);
    mouse-cursor: (edges == 1 || edges == 2) ? MouseCursor.ew-resize
        : (edges == 4 || edges == 8) ? MouseCursor.ns-resize
        : (edges == 5 || edges == 10) ? MouseCursor.nwse-resize
        : MouseCursor.nesw-resize;
    moved => {
        Logic.resize-window(id, edges, self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
    }
    pointer-event(e) => {
        if (e.kind == PointerEventKind.down) {
            root.active(true);
        } else if (e.kind == PointerEventKind.up) {
            root.active(false);
            Logic.focus-window(id);
        }
    }
}

// Renders one client window as a GL texture, forwarding pointer + keyboard to
// the Wayland client. Draws a server-side title bar (draggable to move) when the
// window negotiated server-side decorations, plus resize grips on every edge.
component WindowView inherits Rectangle {
    in property <WindowTile> tile;
    // Bubbled to the desktop while dragging the title bar, to show/apply an
    // edge-snap (maximize / half-screen) preview.
    callback snap-preview(length /* gx */, length /* gy */);
    callback snap-drop(int /* id */, length /* gx */, length /* gy */);

    forward-focus: fs;

    // True while the user is interactively moving/resizing this frame, so the
    // geometry tracks the cursor instantly; maximize / snap changes (made with
    // `interacting` false) glide to their target instead.
    property <bool> interacting: false;

    // Minimize / restore: scale toward the centre and fade (0 = minimized).
    property <float> factor: tile.minimized ? 0.0 : 1.0;
    animate factor { duration: 160ms; easing: ease-in-out; }

    // Host-driven frame geometry, animated so maximize/snap/restore glide.
    property <length> fw: tile.width;
    property <length> fh: tile.height;
    property <length> fx: tile.x;
    property <length> fy: tile.y;
    animate fw, fh, fx, fy { duration: root.interacting ? 0ms : 160ms; easing: ease-in-out; }

    // Stay rendered until the minimize animation finishes, then drop out.
    visible: !tile.minimized || root.factor > 0.005;
    clip: true;
    opacity: root.factor;
    width: root.fw * root.factor;
    height: root.fh * root.factor;
    x: root.fx + (root.fw - self.width) / 2;
    y: root.fy + (root.fh - self.height) / 2;
    // Only server-side-decorated frames get a border/outline — client-side-
    // decorated windows draw (and shadow) their own frame, so any border we add
    // wraps that and looks wrong. Focused = accent outline, else a subtle one.
    border-width: tile.decorated ? (tile.focused ? 1.5px : 1px) : 0px;
    border-color: tile.focused ? Theme.accent : Theme.border;
    border-radius: tile.decorated && !tile.maximized ? 8px : 0px;

    VerticalLayout {
        // Server-side decoration title bar.
        if tile.decorated: Rectangle {
            height: 30px;
            // The active window's bar is accent-tinted; inactive ones stay dim.
            background: tile.focused ? Theme.accent-soft : Theme.sidebar-bg;
            // Drag the bar to move; report the cursor so the desktop can show a
            // snap preview, and snap on release. Double-click toggles maximize.
            TouchArea {
                mouse-cursor: move;
                moved => {
                    root.interacting = true;
                    Logic.move-window(tile.id, self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
                    root.snap-preview(self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                }
                pointer-event(e) => {
                    if (e.kind == PointerEventKind.down) {
                        root.interacting = true;
                    } else if (e.kind == PointerEventKind.up) {
                        root.interacting = false;
                        root.snap-drop(tile.id, self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                        Logic.focus-window(tile.id);
                    }
                }
                double-clicked => { Logic.maximize-window(tile.id); }
            }
            HorizontalLayout {
                padding-left: 10px;
                padding-right: 4px;
                spacing: 2px;
                Text {
                    text: tile.title == "" ? "(untitled)" : tile.title;
                    color: tile.focused ? Theme.text : Theme.text-dim;
                    font-size: Theme.fs-body;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
                min-ta := TouchArea {
                    width: 28px;
                    mouse-cursor: pointer;
                    clicked => { Logic.minimize-window(tile.id); }
                    Rectangle {
                        background: min-ta.has-hover ? Theme.surface-hover : transparent;
                        border-radius: Theme.radius-sm;
                        Text {
                            text: "—";
                            color: Theme.text-dim;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
                max-ta := TouchArea {
                    width: 28px;
                    mouse-cursor: pointer;
                    clicked => { Logic.maximize-window(tile.id); }
                    Rectangle {
                        background: max-ta.has-hover ? Theme.surface-hover : transparent;
                        border-radius: Theme.radius-sm;
                        Text {
                            text: tile.maximized ? "▣" : "□";
                            color: Theme.text-dim;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
                close-ta := TouchArea {
                    width: 28px;
                    mouse-cursor: pointer;
                    clicked => { Logic.close-window(tile.id); }
                    Rectangle {
                        background: close-ta.has-hover ? Theme.notify : transparent;
                        border-radius: Theme.radius-sm;
                        Text {
                            text: "✕";
                            color: close-ta.has-hover ? Theme.accent-text : Theme.text-dim;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        content := Rectangle {
            vertical-stretch: 1;
            Image {
                source: tile.texture;
                image-fit: contain;
                width: 100%;
                height: 100%;
            }

            fs := FocusScope {
                key-pressed(e) => {
                    Logic.key-event(e.text, e.modifiers.control, e.modifiers.alt, e.modifiers.shift, true);
                    accept
                }
                key-released(e) => {
                    Logic.key-event(e.text, e.modifiers.control, e.modifiers.alt, e.modifiers.shift, false);
                    accept
                }

                ta := TouchArea {
                    // Coordinates are relative to the content area (below the
                    // title bar), matching the client's surface 1:1.
                    pointer-event(e) => {
                        fs.focus();
                        if e.kind == PointerEventKind.down {
                            // Clear any stale move flag from a previous drag.
                            AppData.moving-window = -1;
                            Logic.pointer-button(tile.id, ta.mouse-x, ta.mouse-y, root.btn-code(e.button), true);
                        } else if e.kind == PointerEventKind.up {
                            AppData.moving-window = -1;
                            root.interacting = false;
                            Logic.pointer-button(tile.id, ta.mouse-x, ta.mouse-y, root.btn-code(e.button), false);
                            // Raise this window above the others it may overlap.
                            // (After forwarding the release, so the model reorder
                            // can't change tile.id mid-handler.)
                            Logic.focus-window(tile.id);
                        } else if e.kind == PointerEventKind.move {
                            // A client-side-decorated window asked to be moved
                            // (the user is dragging its own title bar): drive the
                            // floating move instead of forwarding the drag.
                            if (AppData.moving-window == tile.id && ta.pressed) {
                                root.interacting = true;
                                Logic.move-window(tile.id, ta.mouse-x - ta.pressed-x, ta.mouse-y - ta.pressed-y);
                            } else {
                                Logic.pointer-moved(tile.id, ta.mouse-x, ta.mouse-y);
                            }
                        }
                    }
                }
            }
        }
    }

    // Resize grips on the frame edges and corners (on top of the content). The
    // corner masks combine two edges: 5=TL, 6=TR, 9=BL, 10=BR. `active` toggles
    // the geometry animation off while a grip is dragged (else it rubber-bands).
    ResizeHandle { id: tile.id; edges: 1; x: 0; y: 12px; width: 6px; height: parent.height - 24px; active(a) => { root.interacting = a; } }
    ResizeHandle { id: tile.id; edges: 2; x: parent.width - 6px; y: 12px; width: 6px; height: parent.height - 24px; active(a) => { root.interacting = a; } }
    ResizeHandle { id: tile.id; edges: 4; x: 12px; y: 0; width: parent.width - 24px; height: 6px; active(a) => { root.interacting = a; } }
    ResizeHandle { id: tile.id; edges: 8; x: 12px; y: parent.height - 6px; width: parent.width - 24px; height: 6px; active(a) => { root.interacting = a; } }
    ResizeHandle { id: tile.id; edges: 5; x: 0; y: 0; width: 12px; height: 12px; active(a) => { root.interacting = a; } }
    ResizeHandle { id: tile.id; edges: 6; x: parent.width - 12px; y: 0; width: 12px; height: 12px; active(a) => { root.interacting = a; } }
    ResizeHandle { id: tile.id; edges: 9; x: 0; y: parent.height - 12px; width: 12px; height: 12px; active(a) => { root.interacting = a; } }
    ResizeHandle { id: tile.id; edges: 10; x: parent.width - 12px; y: parent.height - 12px; width: 12px; height: 12px; active(a) => { root.interacting = a; } }

    pure function btn-code(b: PointerEventButton) -> int {
        b == PointerEventButton.left ? 1
            : b == PointerEventButton.right ? 2
            : b == PointerEventButton.middle ? 3
            : 0
    }
}

export component Desktop inherits Window {
    title: "focuswm";
    preferred-width: 1280px;
    preferred-height: 800px;
    background: Theme.bg;

    in-out property <bool> wizard-open: false;
    in-out property <bool> settings-open: false;
    in-out property <bool> task-settings-open: false;
    in-out property <bool> report-open: false;
    in-out property <bool> launcher-open: false;
    in-out property <bool> locked: false;
    // Active edge-snap zone while dragging a window: 0=none, 1=left half,
    // 2=right half, 3=maximize.
    property <int> snap-zone: 0;

    // Which snap zone the (window-global) cursor is in, by proximity to the
    // window-area edges; 0 when not near an edge or outside the area.
    pure function snap-zone-at(gx: length, gy: length) -> int {
        (gx < windows-area.absolute-position.x
            || gx > windows-area.absolute-position.x + windows-area.width
            || gy < windows-area.absolute-position.y
            || gy > windows-area.absolute-position.y + windows-area.height) ? 0
        : (gy - windows-area.absolute-position.y < 12px) ? 3
        : (gx - windows-area.absolute-position.x < 18px) ? 1
        : (gx - windows-area.absolute-position.x > windows-area.width - 18px) ? 2
        : 0
    }

    // Match std-widgets to the dark theme.
    init => { Palette.color-scheme = ColorScheme.dark; shortcuts.focus(); }

    // Maps a digit key to a 0-based task index, or -1.
    pure function digit-index(t: string) -> int {
        t == "1" ? 0 : t == "2" ? 1 : t == "3" ? 2 : t == "4" ? 3 : t == "5" ? 4
            : t == "6" ? 5 : t == "7" ? 6 : t == "8" ? 7 : t == "9" ? 8 : -1
    }

    // Global shortcuts, captured before keys reach the focused client window.
    shortcuts := FocusScope {
        capture-key-pressed(e) => {
            // Alt+Tab / Alt+Shift+Tab: cycle the active task's windows.
            if (e.modifiers.alt && e.text == Key.Tab) {
                Logic.cycle-window(!e.modifiers.shift);
                return accept;
            }
            // Alt+F2: run-command dialog.
            if (e.modifiers.alt && e.text == Key.F2) {
                launcher.reset();
                root.launcher-open = true;
                return accept;
            }
            if (e.modifiers.meta) {
                if (e.text == Key.Return) { Logic.open-terminal(); return accept; }
                if (e.text == "l") { Logic.lock(); return accept; }
                if (e.text == "w") { Logic.close-active-window(); return accept; }
                if (e.text == "n") { wizard.reset(); root.wizard-open = true; return accept; }
                if (root.digit-index(e.text) >= 0) {
                    Logic.switch-task-index(root.digit-index(e.text));
                    return accept;
                }
            }
            reject
        }

    HorizontalLayout {
        Sidebar {
            add-clicked => {
                wizard.reset();
                root.wizard-open = true;
            }
            launch-clicked => {
                launcher.reset();
                root.launcher-open = true;
            }
        }

        // Window region for the active task (fills the area beside the sidebar).
        windows-area := Rectangle {
            background: Theme.bg;
            horizontal-stretch: 1;
            clip: true;

            if AppData.windows.length == 0: Text {
                text: AppData.active-task < 0
                    ? "Desktop 0 — open a terminal or browser, or pick a task."
                    : "No windows yet — a terminal is opening…";
                color: Theme.text-dim;
                font-size: 14px;
                horizontal-alignment: center;
            }

            // Client windows of the active task as floating frames (last on
            // top). Geometry is host-driven; drag the title bar to move and the
            // edge grips to resize. Minimized windows stay in the sidebar list
            // but aren't shown here.
            for tile[i] in AppData.windows: WindowView {
                tile: tile;
                snap-preview(gx, gy) => { root.snap-zone = root.snap-zone-at(gx, gy); }
                snap-drop(id, gx, gy) => {
                    if (root.snap-zone-at(gx, gy) != 0) {
                        Logic.snap-window(id, root.snap-zone-at(gx, gy));
                    }
                    root.snap-zone = 0;
                }
            }

            // wlr-layer-shell surfaces (panels, notifications, launchers) above
            // the windows, ordered by their layer.
            for l[i] in AppData.layers: ClientSurface {
                id: l.id; texture: l.texture;
                x: l.x; y: l.y; width: l.width; height: l.height;
            }

            // Client popups (menus, dropdowns) on top.
            for p[i] in AppData.popups: ClientSurface {
                id: p.id; texture: p.texture;
                x: p.x; y: p.y; width: p.width; height: p.height;
            }

            // Edge-snap preview: shown while dragging a window's title bar near
            // an edge (1=left half, 2=right half, 3=maximize).
            if root.snap-zone != 0: Rectangle {
                x: root.snap-zone == 2 ? parent.width / 2 : 0px;
                y: 0px;
                width: root.snap-zone == 3 ? parent.width : parent.width / 2;
                height: parent.height;
                background: Theme.accent.with-alpha(0.22);
                border-width: 2px;
                border-color: Theme.accent;
                border-radius: 8px;
            }
        }
    }
    }

    // Creation wizard overlay.
    wizard := Wizard {
        visible: root.wizard-open;
        x: 0; y: 0;
        width: 100%;
        height: 100%;
        close => { root.wizard-open = false; }
    }

    // Settings overlay.
    Settings {
        visible: root.settings-open;
        x: 0; y: 0;
        width: 100%;
        height: 100%;
        close => { root.settings-open = false; }
    }

    // Per-task settings overlay.
    TaskSettings {
        visible: root.task-settings-open;
        x: 0; y: 0;
        width: 100%;
        height: 100%;
        close => { root.task-settings-open = false; }
    }

    // Report overlay.
    Report {
        visible: root.report-open;
        x: 0; y: 0;
        width: 100%;
        height: 100%;
        close => { root.report-open = false; }
    }

    // Run-command launcher overlay.
    launcher := Launcher {
        visible: root.launcher-open;
        x: 0; y: 0;
        width: 100%;
        height: 100%;
        close => { root.launcher-open = false; }
    }

    // Notification toasts (top-right stack).
    VerticalLayout {
        x: root.width - self.width - 16px;
        y: 16px;
        width: 320px;
        spacing: 8px;
        for n[i] in AppData.notifications: TouchArea {
            height: card.preferred-height;
            mouse-cursor: pointer;
            clicked => { Logic.dismiss-notification(n.id); }
            card := Rectangle {
                background: Theme.surface;
                border-radius: Theme.radius;
                border-width: 1px;
                border-color: Theme.border;
                drop-shadow-blur: 16px;
                drop-shadow-color: Theme.shadow-color;
                VerticalLayout {
                    padding: 12px;
                    spacing: 3px;
                    if n.app != "": Text {
                        text: n.app;
                        color: Theme.accent;
                        font-size: Theme.fs-small;
                        font-weight: 700;
                        overflow: elide;
                    }
                    Text {
                        text: n.summary;
                        color: Theme.text;
                        font-size: Theme.fs-body;
                        font-weight: 600;
                        wrap: word-wrap;
                    }
                    if n.body != "": Text {
                        text: n.body;
                        color: Theme.text-dim;
                        font-size: Theme.fs-small;
                        wrap: word-wrap;
                    }
                }
            }
        }
    }

    // Lock screen (top-most overlay).
    LockScreen {
        visible: root.locked;
        x: 0; y: 0;
        width: 100%;
        height: 100%;
    }
}
