import { Theme } from "theme.slint";
import { AppData, Logic, ReportData, SettingsData, ReportRow } from "globals.slint";
import { TaskItem, WindowTile } from "types.slint";
import { Sidebar } from "sidebar.slint";
import { Wizard } from "wizard.slint";
import { Settings } from "settings.slint";
import { Report } from "report.slint";
import { LockScreen } from "lock.slint";
import { Palette } from "std-widgets.slint";

export { AppData, Logic, ReportData, SettingsData, ReportRow, TaskItem, WindowTile, Theme }

// Renders one client window as a GL texture, forwarding pointer + keyboard to
// the Wayland client. Draws a server-side title bar when the window negotiated
// server-side decorations.
component WindowView inherits Rectangle {
    in property <WindowTile> tile;

    forward-focus: fs;

    VerticalLayout {
        // Server-side decoration title bar.
        if tile.decorated: Rectangle {
            height: 30px;
            background: Theme.sidebar-bg;
            HorizontalLayout {
                padding-left: 10px;
                padding-right: 4px;
                spacing: 6px;
                Text {
                    text: tile.title == "" ? "(untitled)" : tile.title;
                    color: Theme.text;
                    font-size: Theme.fs-body;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
                close-ta := TouchArea {
                    width: 30px;
                    mouse-cursor: pointer;
                    clicked => { Logic.close-window(tile.id); }
                    Text {
                        text: "✕";
                        color: close-ta.has-hover ? Theme.notify : Theme.text-dim;
                        font-size: 13px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        content := Rectangle {
            vertical-stretch: 1;
            Image {
                source: tile.texture;
                image-fit: contain;
                width: 100%;
                height: 100%;
            }

            fs := FocusScope {
                key-pressed(e) => {
                    Logic.key-event(e.text, e.modifiers.control, e.modifiers.alt, e.modifiers.shift, true);
                    accept
                }
                key-released(e) => {
                    Logic.key-event(e.text, e.modifiers.control, e.modifiers.alt, e.modifiers.shift, false);
                    accept
                }

                ta := TouchArea {
                    // Coordinates are relative to the content area (below the
                    // title bar), matching the client's surface 1:1.
                    pointer-event(e) => {
                        fs.focus();
                        if e.kind == PointerEventKind.down {
                            Logic.pointer-button(tile.id, ta.mouse-x, ta.mouse-y, root.btn-code(e.button), true);
                        } else if e.kind == PointerEventKind.up {
                            Logic.pointer-button(tile.id, ta.mouse-x, ta.mouse-y, root.btn-code(e.button), false);
                        } else if e.kind == PointerEventKind.move {
                            Logic.pointer-moved(tile.id, ta.mouse-x, ta.mouse-y);
                        }
                    }
                }
            }
        }
    }

    pure function btn-code(b: PointerEventButton) -> int {
        b == PointerEventButton.left ? 1
            : b == PointerEventButton.right ? 2
            : b == PointerEventButton.middle ? 3
            : 0
    }
}

export component Desktop inherits Window {
    title: "focuswm";
    preferred-width: 1280px;
    preferred-height: 800px;
    background: Theme.bg;

    in-out property <bool> wizard-open: false;
    in-out property <bool> settings-open: false;
    in-out property <bool> report-open: false;
    in-out property <bool> locked: false;
    property <bool> has-active: AppData.active-task >= 0;

    // Match std-widgets to the dark theme.
    init => { Palette.color-scheme = ColorScheme.dark; }

    HorizontalLayout {
        Sidebar {
            add-clicked => {
                wizard.reset();
                root.wizard-open = true;
            }
        }

        // Window region for the active task (fills the area beside the sidebar).
        Rectangle {
            background: Theme.bg;
            horizontal-stretch: 1;

            if AppData.windows.length == 0 && root.has-active: Text {
                text: "No windows yet — a terminal is opening…";
                color: Theme.text-dim;
                font-size: 14px;
            }
            if !root.has-active: Text {
                text: "Create a task to get started.";
                color: Theme.text-dim;
                font-size: 16px;
            }

            // Client windows of the active task, stacked (last on top).
            for tile[i] in AppData.windows: WindowView {
                tile: tile;
                x: 0; y: 0;
                width: 100%;
                height: 100%;
            }
        }
    }

    // Creation wizard overlay.
    wizard := Wizard {
        visible: root.wizard-open;
        x: 0; y: 0;
        width: 100%;
        height: 100%;
        close => { root.wizard-open = false; }
    }

    // Settings overlay.
    Settings {
        visible: root.settings-open;
        x: 0; y: 0;
        width: 100%;
        height: 100%;
        close => { root.settings-open = false; }
    }

    // Report overlay.
    Report {
        visible: root.report-open;
        x: 0; y: 0;
        width: 100%;
        height: 100%;
        close => { root.report-open = false; }
    }

    // Lock screen (top-most overlay).
    LockScreen {
        visible: root.locked;
        x: 0; y: 0;
        width: 100%;
        height: 100%;
    }
}
