import { Theme } from "theme.slint";
import { ReportData, ReportRow } from "globals.slint";
import { Button } from "std-widgets.slint";

// A small table of report rows. With `single`, only one value column is shown
// (used for the per-day list).
component ReportTable inherits VerticalLayout {
    in property <string> title;
    in property <[ReportRow]> rows;
    in property <bool> single: false;
    spacing: 3px;

    Text { text: root.title; color: Theme.text; font-size: 14px; font-weight: 600; }

    HorizontalLayout {
        spacing: 8px;
        Text { text: ""; horizontal-stretch: 1; }
        if !root.single: Text {
            text: "Today"; color: Theme.text-dim; font-size: 11px;
            width: 72px; horizontal-alignment: right;
        }
        Text {
            text: root.single ? "Time" : "Week"; color: Theme.text-dim; font-size: 11px;
            width: 72px; horizontal-alignment: right;
        }
    }

    for r in root.rows: HorizontalLayout {
        spacing: 8px;
        Text {
            text: r.label; color: Theme.text; font-size: 13px;
            horizontal-stretch: 1; overflow: elide;
        }
        if !root.single: Text {
            text: r.today; color: Theme.text-dim; font-size: 13px;
            width: 72px; horizontal-alignment: right;
        }
        Text {
            text: root.single ? r.today : r.week; color: Theme.text; font-size: 13px;
            width: 72px; horizontal-alignment: right;
        }
    }

    if root.rows.length == 0: Text {
        text: "No time logged yet."; color: Theme.text-dim; font-size: 12px;
    }
}

// Time report dialog.
export component Report inherits Rectangle {
    callback close();
    background: #000000aa;

    TouchArea {
        clicked => { root.close(); }
    }

    Rectangle {
        width: 540px;
        height: layout.preferred-height + 2 * 20px;
        background: Theme.bg;
        border-radius: 12px;
        border-width: 1px;
        border-color: Theme.surface;

        TouchArea {}

        layout := VerticalLayout {
            padding: 20px;
            spacing: 16px;

            Text { text: "Time report"; color: Theme.text; font-size: 20px; font-weight: 700; }

            HorizontalLayout {
                spacing: 40px;
                VerticalLayout {
                    Text { text: "Today"; color: Theme.text-dim; font-size: 12px; }
                    Text { text: ReportData.today-total; color: Theme.accent; font-size: 24px; font-weight: 700; }
                }
                VerticalLayout {
                    Text { text: "This week"; color: Theme.text-dim; font-size: 12px; }
                    Text { text: ReportData.week-total; color: Theme.accent; font-size: 24px; font-weight: 700; }
                }
            }

            ReportTable { title: "By category"; rows: ReportData.by-category; }
            ReportTable { title: "By project"; rows: ReportData.by-project; }
            ReportTable { title: "Last 7 days"; rows: ReportData.daily; single: true; }

            HorizontalLayout {
                alignment: end;
                Button { text: "Close"; clicked => { root.close(); } }
            }
        }
    }
}
