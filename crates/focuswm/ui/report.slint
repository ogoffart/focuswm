import { Theme, Card } from "theme.slint";
import { ReportData, ReportRow, DayBar, Logic } from "globals.slint";
import { Button } from "std-widgets.slint";

// A small two-column table of report rows (Day / Week).
component ReportTable inherits VerticalLayout {
    in property <string> title;
    in property <[ReportRow]> rows;
    spacing: 3px;

    Text { text: root.title; color: Theme.text; font-size: 14px; font-weight: 600; }

    HorizontalLayout {
        spacing: 8px;
        Text { text: ""; horizontal-stretch: 1; }
        Text { text: "Day"; color: Theme.text-dim; font-size: 11px; width: 96px; horizontal-alignment: right; }
        Text { text: "Week"; color: Theme.text-dim; font-size: 11px; width: 96px; horizontal-alignment: right; }
    }
    for r in root.rows: HorizontalLayout {
        spacing: 8px;
        Text { text: r.label; color: Theme.text; font-size: 13px; horizontal-stretch: 1; overflow: elide; }
        Text { text: r.today; color: Theme.text-dim; font-size: 13px; width: 96px; horizontal-alignment: right; }
        Text { text: r.week; color: Theme.text; font-size: 13px; width: 96px; horizontal-alignment: right; }
    }
    if root.rows.length == 0: Text { text: "No time logged."; color: Theme.text-dim; font-size: 12px; }
}

// A bar chart of the selected week's daily totals.
component WeekGraph inherits VerticalLayout {
    in property <[DayBar]> bars;
    spacing: 4px;
    Text { text: "This week"; color: Theme.text; font-size: 14px; font-weight: 600; }
    HorizontalLayout {
        height: 120px;
        spacing: 8px;
        for b in root.bars: VerticalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            // Bar area (grows from the bottom).
            bararea := Rectangle {
                vertical-stretch: 1;
                Rectangle {
                    width: 70%;
                    x: (parent.width - self.width) / 2;
                    height: max(2px, bararea.height * b.fraction);
                    y: bararea.height - self.height;
                    background: b.selected ? Theme.accent : Theme.accent-dim;
                    border-radius: 3px;
                }
            }
            Text {
                text: b.value;
                color: Theme.text-dim;
                font-size: 10px;
                horizontal-alignment: center;
            }
            Text {
                text: b.label;
                color: b.selected ? Theme.accent : Theme.text-dim;
                font-size: 11px;
                font-weight: b.selected ? 700 : 400;
                horizontal-alignment: center;
            }
        }
    }
}

// Time report dialog with day/week navigation and a weekly graph.
export component Report inherits Rectangle {
    callback close();
    background: Theme.scrim;

    TouchArea { clicked => { root.close(); } }

    Card {
        width: 560px;
        height: layout.preferred-height + 2 * Theme.sp-6;

        TouchArea {}

        layout := VerticalLayout {
            padding: Theme.sp-6;
            spacing: Theme.sp-4;

            Text { text: "Time report"; color: Theme.text; font-size: Theme.fs-title; font-weight: 700; }

            // Day selector + totals.
            HorizontalLayout {
                spacing: 12px;
                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 2px;
                    HorizontalLayout {
                        spacing: 6px;
                        Button { text: "‹"; width: 32px; clicked => { Logic.report-prev-day(); } }
                        Text {
                            text: ReportData.day-label;
                            color: Theme.text-dim;
                            font-size: 12px;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                            horizontal-stretch: 1;
                        }
                        Button { text: "›"; width: 32px; enabled: ReportData.can-forward; clicked => { Logic.report-next-day(); } }
                    }
                    Text { text: ReportData.day-total; color: Theme.accent; font-size: 24px; font-weight: 700; horizontal-alignment: center; }
                }
                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 2px;
                    HorizontalLayout {
                        spacing: 6px;
                        Button { text: "‹"; width: 32px; clicked => { Logic.report-prev-week(); } }
                        Text {
                            text: ReportData.week-label;
                            color: Theme.text-dim;
                            font-size: 12px;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                            horizontal-stretch: 1;
                        }
                        Button { text: "›"; width: 32px; enabled: ReportData.can-forward; clicked => { Logic.report-next-week(); } }
                    }
                    Text { text: ReportData.week-total; color: Theme.accent; font-size: 24px; font-weight: 700; horizontal-alignment: center; }
                }
            }

            WeekGraph { bars: ReportData.week-bars; }

            ReportTable { title: "By category"; rows: ReportData.by-category; }
            ReportTable { title: "By project"; rows: ReportData.by-project; }

            HorizontalLayout {
                alignment: end;
                Button { text: "Close"; clicked => { root.close(); } }
            }
        }
    }
}
