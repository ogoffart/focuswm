import { Theme, Card } from "theme.slint";
import { Logic, SettingsData } from "globals.slint";
import { LineEdit, Button } from "std-widgets.slint";

// Settings dialog: terminal/browser commands and the category list.
export component Settings inherits Rectangle {
    callback close();
    background: Theme.scrim;

    // Backdrop click cancels.
    TouchArea {
        clicked => { root.close(); }
    }

    Card {
        width: 460px;
        height: layout.preferred-height + 2 * Theme.sp-6;

        TouchArea {} // eat clicks on the card

        layout := VerticalLayout {
            padding: Theme.sp-6;
            spacing: Theme.sp-4;

            Text { text: "Settings"; color: Theme.text; font-size: Theme.fs-title; font-weight: 700; }

            VerticalLayout {
                spacing: 4px;
                Text { text: "Terminal command (blank = auto-detect)"; color: Theme.text-dim; font-size: 12px; }
                term := LineEdit { text: SettingsData.terminal; placeholder-text: "alacritty"; }
            }
            VerticalLayout {
                spacing: 4px;
                Text { text: "Browser command (blank = auto-detect)"; color: Theme.text-dim; font-size: 12px; }
                brow := LineEdit { text: SettingsData.browser; placeholder-text: "firefox"; }
            }
            VerticalLayout {
                spacing: 4px;
                Text { text: "Categories (comma-separated)"; color: Theme.text-dim; font-size: 12px; }
                cats := LineEdit { text: SettingsData.categories-csv; placeholder-text: "work, personal, learning"; }
            }
            VerticalLayout {
                spacing: 4px;
                Text { text: "Idle timeout in minutes (0 = never pause)"; color: Theme.text-dim; font-size: 12px; }
                idle := LineEdit { text: SettingsData.idle-minutes; placeholder-text: "5"; input-type: number; }
            }

            HorizontalLayout {
                spacing: 10px;
                alignment: end;
                Button { text: "Cancel"; clicked => { root.close(); } }
                Button {
                    text: "Save";
                    primary: true;
                    clicked => {
                        Logic.save-settings(term.text, brow.text, cats.text, idle.text);
                        root.close();
                    }
                }
            }
        }
    }
}
