import { Theme } from "theme.slint";
import { AppData, Logic } from "globals.slint";
import { TaskItem, WindowTile } from "types.slint";
import { WindowMenu } from "window_menu.slint";
import { Button } from "std-widgets.slint";

// A divider plus an uppercase section label.
component SectionHeader inherits VerticalLayout {
    in property <string> text;
    spacing: 8px;
    Rectangle { height: 1px; background: Theme.border; }
    Text {
        text: root.text;
        color: Theme.text-faint;
        font-size: Theme.fs-small;
        font-weight: 700;
        letter-spacing: 0.8px;
    }
}

// A window belonging to the active task.
component WindowRow inherits Rectangle {
    in property <WindowTile> win;
    callback activate();
    callback close();
    callback minimize();
    callback maximize();

    height: 34px;
    border-radius: Theme.radius-sm;
    background: touch.has-hover ? Theme.surface-hover : Theme.surface;
    animate background { duration: 120ms; }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.activate(); }
    }

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 6px;
        spacing: 6px;
        Text {
            // Minimized windows show a different glyph and dim out.
            text: win.minimized ? "▭" : "🗔";
            font-size: 12px;
            color: Theme.text-dim;
            vertical-alignment: center;
        }
        Text {
            text: win.title == "" ? "(untitled)" : win.title;
            color: win.minimized ? Theme.text-faint : Theme.text;
            font-size: Theme.fs-body;
            overflow: elide;
            horizontal-stretch: 1;
            vertical-alignment: center;
        }
        close-ta := TouchArea {
            width: 18px;
            mouse-cursor: pointer;
            clicked => { root.close(); }
            Text {
                text: "✕";
                color: close-ta.has-hover ? Theme.notify : Theme.text-dim;
                font-size: 11px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    // Right-click context menu (top-most, full-area; non-grabbing so left-clicks
    // fall through to the row / its ✕). Shared with the title-bar menu.
    WindowMenu {
        width: 100%;
        height: 100%;
        win: root.win;
    }
}

// Desktop 0 — the scratch desktop, always present and not tied to any task.
component Desktop0Row inherits Rectangle {
    in property <bool> active;
    callback clicked();

    height: 44px;
    border-radius: Theme.radius;
    background: active ? Theme.accent-soft : (touch.has-hover ? Theme.surface-hover : Theme.surface);
    animate background { duration: 140ms; }

    // Left accent bar for the active desktop (neutral, since it has no colour).
    Rectangle {
        x: 0;
        width: 3px;
        height: active ? parent.height - 16px : 0px;
        y: parent.height / 2 - self.height / 2;
        border-radius: 2px;
        background: Theme.text-dim;
        animate height { duration: 140ms; }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding: 10px;
        padding-left: 12px;
        spacing: 8px;
        Text {
            text: "🖥";
            font-size: 14px;
            vertical-alignment: center;
        }
        Text {
            text: "Desktop 0";
            color: active ? Theme.accent : Theme.text;
            font-size: Theme.fs-body;
            font-weight: 600;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }
}

// A single task row in the sidebar.
component TaskRow inherits Rectangle {
    in property <TaskItem> task;
    in property <bool> active;
    callback clicked();
    callback up();
    callback down();
    callback remove();
    // Open this task's settings dialog (from the context menu's "Settings…").
    callback edit();
    // Drag-to-reorder: started on this row, dragged by `dy`, then dropped.
    callback drag-start();
    callback drag-move(length /* dy from press */);
    callback drag-end();
    // True once a press on this row has turned into a vertical drag.
    property <bool> dragging-row: false;

    border-radius: Theme.radius;
    background: active ? Theme.accent-soft : (touch.has-hover ? Theme.surface-hover : Theme.surface);
    animate background { duration: 140ms; }

    // Left accent bar, in the task's own colour, for the active task.
    Rectangle {
        x: 0;
        width: 3px;
        height: active ? parent.height - 16px : 0px;
        y: parent.height / 2 - self.height / 2;
        border-radius: 2px;
        background: task.tint;
        animate height { duration: 140ms; }
    }

    // Press-and-tap selects the task; press-and-drag vertically reorders it.
    // The drag delta is reported relative to the press; the host accumulates it.
    touch := TouchArea {
        mouse-cursor: root.dragging-row ? MouseCursor.grabbing : MouseCursor.pointer;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                root.dragging-row = false;
                root.drag-start();
            } else if (e.kind == PointerEventKind.up) {
                if (root.dragging-row) { root.drag-end(); } else { root.clicked(); }
                root.dragging-row = false;
            }
        }
        moved => {
            if (!root.dragging-row
                && (self.mouse-y - self.pressed-y > 4px || self.pressed-y - self.mouse-y > 4px)) {
                root.dragging-row = true;
            }
            if (root.dragging-row) {
                root.drag-move(self.mouse-y - self.pressed-y);
            }
        }
    }

    HorizontalLayout {
        padding: 10px;
        padding-left: 12px;
        spacing: 8px;

        // Colour dot, doubling as the notification indicator (turns the
        // notify colour while a notification is pending).
        Rectangle {
            width: 8px;
            vertical-stretch: 1;
            Rectangle {
                width: 8px;
                height: 8px;
                border-radius: 4px;
                y: parent.height / 2 - self.height / 2;
                background: task.has-notification ? Theme.notify : task.tint;
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 3px;
            Text {
                text: task.name;
                color: active ? Theme.accent : Theme.text;
                font-size: Theme.fs-body;
                font-weight: 600;
                overflow: elide;
            }
            Text {
                text: task.category + " · " + task.minutes + " min";
                color: Theme.text-faint;
                font-size: Theme.fs-small;
                overflow: elide;
            }
        }

        // Per-row controls, revealed on hover (clipped so they don't leak
        // out of the collapsed 0-width box).
        Rectangle {
            clip: true;
            width: touch.has-hover || root.active ? 20px : 0px;
            animate width { duration: 120ms; }
            VerticalLayout {
                width: 20px;
                spacing: 2px;
                alignment: center;
                TouchArea {
                    width: 20px; height: 18px;
                    mouse-cursor: pointer;
                    clicked => { root.up(); }
                    Text { text: "▲"; color: parent.has-hover ? Theme.text : Theme.text-faint; font-size: 9px;
                           horizontal-alignment: center; vertical-alignment: center; }
                }
                TouchArea {
                    width: 20px; height: 18px;
                    mouse-cursor: pointer;
                    clicked => { root.remove(); }
                    Text { text: "✕"; color: parent.has-hover ? Theme.notify : Theme.text-faint; font-size: 11px;
                           horizontal-alignment: center; vertical-alignment: center; }
                }
                TouchArea {
                    width: 20px; height: 18px;
                    mouse-cursor: pointer;
                    clicked => { root.down(); }
                    Text { text: "▼"; color: parent.has-hover ? Theme.text : Theme.text-faint; font-size: 9px;
                           horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }
    }

    // Right-click (or the Menu key) opens the per-task context menu. Kept as the
    // top-most, full-area sibling so it catches right-clicks; it ignores other
    // buttons, which then fall through to `touch` and the hover controls.
    ContextMenuArea {
        width: 100%;
        height: 100%;
        Menu {
            MenuItem {
                title: "Settings…";
                activated => { root.edit(); }
            }
            MenuItem {
                title: "Move up";
                activated => { root.up(); }
            }
            MenuItem {
                title: "Move down";
                activated => { root.down(); }
            }
            MenuSeparator {}
            MenuItem {
                title: "Delete";
                activated => { root.remove(); }
            }
        }
    }
}

export component Sidebar inherits Rectangle {
    callback add-clicked();
    callback launch-clicked();
    width: Theme.sidebar-width;
    background: Theme.sidebar-bg;

    // Task-list geometry + drag-to-reorder state.
    property <length> row-height: 58px;
    property <length> row-pitch: 64px; // row height + 6px gap
    property <int> drag-index: -1;     // which row is being dragged, or -1
    property <length> drag-dy: 0;      // its accumulated vertical offset

    // The y of task row `i` while a drag is in progress: the dragged row follows
    // the cursor; rows between its origin and current slot shift by one pitch to
    // open a gap where it will drop.
    function slot-y(i: int) -> length {
        if (root.drag-index < 0) {
            return i * root.row-pitch;
        }
        if (i == root.drag-index) {
            return i * root.row-pitch + root.drag-dy;
        }
        if (i > root.drag-index && root.drag-dy + root.row-pitch / 2 >= (i - root.drag-index) * root.row-pitch) {
            return (i - 1) * root.row-pitch;
        }
        if (i < root.drag-index && -root.drag-dy + root.row-pitch / 2 >= (root.drag-index - i) * root.row-pitch) {
            return (i + 1) * root.row-pitch;
        }
        return i * root.row-pitch;
    }

    VerticalLayout {
        padding: Theme.padding;
        spacing: Theme.spacing;

        // Clock: time + date.
        VerticalLayout {
            spacing: 0px;
            Text {
                text: AppData.clock-time;
                color: Theme.text;
                font-size: 30px;
                font-weight: 300;
                letter-spacing: 1px;
            }
            Text {
                text: AppData.clock-date;
                color: Theme.text-dim;
                font-size: Theme.fs-label;
            }
        }
        Rectangle { height: 1px; background: Theme.border; }

        // Header + add button.
        HorizontalLayout {
            alignment: space-between;
            Text {
                text: "Tasks";
                color: Theme.text;
                font-size: 18px;
                font-weight: 700;
                letter-spacing: 0.3px;
                vertical-alignment: center;
            }
            add := TouchArea {
                width: 32px;
                height: 32px;
                mouse-cursor: pointer;
                clicked => { root.add-clicked(); }
                Rectangle {
                    border-radius: Theme.radius;
                    background: add.has-hover ? Theme.accent : Theme.surface;
                    animate background { duration: 120ms; }
                    Text {
                        text: "+";
                        color: add.has-hover ? Theme.accent-text : Theme.text;
                        font-size: 22px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Desktop 0 — always present, above the tasks.
        Desktop0Row {
            active: AppData.active-task < 0;
            clicked => { Logic.switch-to-desktop0(); }
        }

        // The task list. Rows are positioned manually (not via a layout) so a
        // dragged row can float and its neighbours can slide aside. The Flickable
        // is non-interactive (wheel scrolls; drags are for reordering, not
        // flicking) so it never steals the reorder gesture.
        Flickable {
            vertical-stretch: 1;
            interactive: false;
            viewport-width: self.width;
            viewport-height: AppData.tasks.length * root.row-pitch;
            for task[i] in AppData.tasks: TaskRow {
                x: 0;
                width: 100%;
                height: root.row-height;
                y: root.slot-y(i);
                task: task;
                active: task.id == AppData.active-task;
                clicked => { Logic.switch-task(task.id); }
                up => { Logic.move-task(task.id, -1); }
                down => { Logic.move-task(task.id, 1); }
                remove => { Logic.delete-task(task.id); }
                edit => { Logic.open-task-settings(task.id); }
                drag-start => { root.drag-index = i; root.drag-dy = 0; }
                drag-move(dy) => { root.drag-dy += dy; }
                drag-end => {
                    Logic.reorder-task(task.id, root.drag-dy);
                    root.drag-index = -1;
                    root.drag-dy = 0;
                }
            }
        }

        if AppData.tasks.length == 0: Text {
            text: "No tasks yet.\nClick + to create one.";
            color: Theme.text-dim;
            font-size: 12px;
            horizontal-alignment: center;
        }

        // Windows of the active task.
        if AppData.windows.length > 0: VerticalLayout {
            vertical-stretch: 0;
            spacing: 6px;
            SectionHeader { text: "WINDOWS"; }
            for win[i] in AppData.windows: WindowRow {
                win: win;
                activate => { Logic.focus-window(win.id); }
                close => { Logic.close-window(win.id); }
                minimize => { Logic.minimize-window(win.id); }
                maximize => { Logic.maximize-window(win.id); }
            }
        }

        // Actions for the active desktop (available on desktop 0 too).
        VerticalLayout {
            vertical-stretch: 0;
            spacing: 6px;
            Rectangle {
                height: 1px;
                background: Theme.border;
            }
            Button {
                height: 34px;
                text: "⌨  Terminal";
                clicked => { Logic.open-terminal(); }
            }
            Button {
                height: 34px;
                text: "🌐  Browser";
                clicked => { Logic.open-browser(); }
            }
        }

        // System-tray icons.
        if AppData.tray.length > 0: HorizontalLayout {
            vertical-stretch: 0;
            spacing: 8px;
            alignment: start;
            for t[i] in AppData.tray: ta := TouchArea {
                width: 26px;
                height: 26px;
                mouse-cursor: pointer;
                clicked => { Logic.tray-activate(t.id); }
                Rectangle {
                    border-radius: Theme.radius-sm;
                    background: ta.has-hover ? Theme.surface-hover : transparent;
                    Image {
                        source: t.icon;
                        width: 18px;
                        height: 18px;
                    }
                }
            }
        }

        // Always-available app menu: lock, settings, time report.
        HorizontalLayout {
            vertical-stretch: 0;
            spacing: 6px;
            Button {
                height: 32px;
                width: 40px;
                text: "🔒";
                clicked => { Logic.lock(); }
            }
            Button {
                height: 32px;
                width: 40px;
                text: "⚙";
                clicked => { Logic.open-settings(); }
            }
            Button {
                height: 32px;
                width: 40px;
                text: "▶";
                clicked => { root.launch-clicked(); }
            }
            Button {
                height: 32px;
                text: "📊  Report";
                horizontal-stretch: 1;
                clicked => { Logic.open-report(); }
            }
        }
    }
}
