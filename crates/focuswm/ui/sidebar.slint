import { Theme } from "theme.slint";
import { AppData, Logic } from "globals.slint";
import { TaskItem } from "types.slint";

// A single task row in the sidebar.
component TaskRow inherits Rectangle {
    in property <TaskItem> task;
    in property <bool> active;
    callback clicked();
    callback up();
    callback down();
    callback remove();

    height: 60px;
    border-radius: Theme.radius;
    background: active ? Theme.accent-dim : (touch.has-hover ? Theme.surface-hover : Theme.surface);
    animate background { duration: 120ms; }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding: 10px;
        spacing: 8px;

        // Notification dot / active marker.
        Rectangle {
            width: 8px;
            vertical-stretch: 1;
            Rectangle {
                width: 8px;
                height: 8px;
                border-radius: 4px;
                y: parent.height / 2 - self.height / 2;
                background: task.has-notification ? Theme.notify : transparent;
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 2px;
            Text {
                text: task.name;
                color: Theme.text;
                font-size: 14px;
                font-weight: 600;
                overflow: elide;
            }
            Text {
                text: task.category + " · " + task.minutes + " min";
                color: Theme.text-dim;
                font-size: 11px;
                overflow: elide;
            }
        }

        // Per-row controls, revealed on hover (clipped so they don't leak out of
        // the collapsed 0-width box).
        Rectangle {
            clip: true;
            width: touch.has-hover || root.active ? 20px : 0px;
            animate width { duration: 120ms; }
            VerticalLayout {
                width: 20px;
                spacing: 2px;
                alignment: center;
                TouchArea {
                    width: 20px; height: 18px;
                    clicked => { root.up(); }
                    Text { text: "▲"; color: Theme.text-dim; font-size: 9px;
                           horizontal-alignment: center; vertical-alignment: center; }
                }
                TouchArea {
                    width: 20px; height: 18px;
                    clicked => { root.remove(); }
                    Text { text: "✕"; color: Theme.notify; font-size: 11px;
                           horizontal-alignment: center; vertical-alignment: center; }
                }
                TouchArea {
                    width: 20px; height: 18px;
                    clicked => { root.down(); }
                    Text { text: "▼"; color: Theme.text-dim; font-size: 9px;
                           horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }
    }
}

export component Sidebar inherits Rectangle {
    callback add-clicked();
    width: Theme.sidebar-width;
    background: Theme.sidebar-bg;

    VerticalLayout {
        padding: Theme.padding;
        spacing: Theme.spacing;

        // Header + add button.
        HorizontalLayout {
            alignment: space-between;
            Text {
                text: "Tasks";
                color: Theme.text;
                font-size: 18px;
                font-weight: 700;
                vertical-alignment: center;
            }
            add := TouchArea {
                width: 32px;
                height: 32px;
                clicked => { root.add-clicked(); }
                Rectangle {
                    border-radius: Theme.radius;
                    background: add.has-hover ? Theme.accent : Theme.surface;
                    animate background { duration: 120ms; }
                    Text {
                        text: "+";
                        color: add.has-hover ? Theme.sidebar-bg : Theme.text;
                        font-size: 22px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // The task list.
        Flickable {
            vertical-stretch: 1;
            VerticalLayout {
                spacing: 6px;
                alignment: start;
                for task[i] in AppData.tasks: TaskRow {
                    task: task;
                    active: task.id == AppData.active-task;
                    clicked => { Logic.switch-task(task.id); }
                    up => { Logic.move-task(task.id, -1); }
                    down => { Logic.move-task(task.id, 1); }
                    remove => { Logic.delete-task(task.id); }
                }
            }
        }

        if AppData.tasks.length == 0: Text {
            text: "No tasks yet.\nClick + to create one.";
            color: Theme.text-dim;
            font-size: 12px;
            horizontal-alignment: center;
        }
    }
}
