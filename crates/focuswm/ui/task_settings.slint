import { Theme, Card } from "theme.slint";
import { AppData, Logic, TaskSettingsData } from "globals.slint";
import { LineEdit, Button, ComboBox } from "std-widgets.slint";

// Per-task settings dialog: rename a virtual desktop, change its category and
// pick its accent colour. Shown as a full-window overlay; the caller toggles
// `visible`. Field state lives in TaskSettingsData (reset by the host on open),
// so the dialog always reflects the task it was opened for.
export component TaskSettings inherits Rectangle {
    callback close();
    background: Theme.scrim;

    // Backdrop click cancels.
    TouchArea {
        clicked => { root.close(); }
    }

    Card {
        width: 460px;
        height: layout.preferred-height + 2 * Theme.sp-6;

        TouchArea {} // eat clicks on the card

        layout := VerticalLayout {
            padding: Theme.sp-6;
            spacing: Theme.sp-4;

            Text { text: "Task settings"; color: Theme.text; font-size: Theme.fs-title; font-weight: 700; }

            VerticalLayout {
                spacing: 4px;
                Text { text: "Name"; color: Theme.text-dim; font-size: 12px; }
                name := LineEdit { text <=> TaskSettingsData.name; placeholder-text: "What are you working on?"; }
            }
            VerticalLayout {
                spacing: 4px;
                Text { text: "Category"; color: Theme.text-dim; font-size: 12px; }
                category-box := ComboBox {
                    model: AppData.categories;
                    current-index <=> TaskSettingsData.category-index;
                }
            }
            VerticalLayout {
                spacing: 4px;
                Text { text: "Colour"; color: Theme.text-dim; font-size: 12px; }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    for c[i] in TaskSettingsData.palette: Rectangle {
                        width: 30px;
                        height: 30px;
                        border-radius: 15px;
                        background: c;
                        border-width: i == TaskSettingsData.selected-index ? 3px : 0px;
                        border-color: Theme.text;
                        swatch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { TaskSettingsData.selected-index = i; }
                        }
                    }
                }
            }

            HorizontalLayout {
                spacing: 10px;
                alignment: end;
                Button { text: "Cancel"; clicked => { root.close(); } }
                Button {
                    text: "Save";
                    primary: true;
                    enabled: name.text != "";
                    clicked => {
                        Logic.save-task-settings(
                            TaskSettingsData.id,
                            name.text,
                            category-box.current-value,
                            TaskSettingsData.selected-index,
                        );
                        root.close();
                    }
                }
            }
        }
    }
}
