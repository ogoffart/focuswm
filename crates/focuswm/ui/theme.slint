// Centralized colours and metrics.
export global Theme {
    out property <color> bg: #1e1e2e;
    out property <color> sidebar-bg: #181825;
    out property <color> surface: #313244;
    out property <color> surface-hover: #45475a;
    out property <color> accent: #89b4fa;
    out property <color> accent-dim: #5a6aa0;
    out property <color> text: #cdd6f4;
    out property <color> text-dim: #9399b2;
    out property <color> notify: #f38ba8;
    out property <color> overlay: #000000;

    out property <length> sidebar-width: 240px;
    out property <length> radius: 8px;
    out property <length> spacing: 8px;
    out property <length> padding: 12px;
    out property <length> header-height: 44px;
}
