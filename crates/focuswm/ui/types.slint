// Shared data structures mirrored from Rust (focuswm-shell / main.rs).

// One task = one virtual desktop, as shown in the sidebar.
export struct TaskItem {
    id: int,
    name: string,
    category: string,
    // Accumulated focus time, in whole minutes.
    minutes: int,
    has-notification: bool,
    // Accent colour shown in the sidebar (resolved host-side from the task's
    // stored hex colour).
    tint: color,
}

// One client window, rendered as a GL texture in the active task's view.
// Floating: `x`/`y` are the window frame's top-left in the content area and
// `width`/`height` are the whole frame size (title bar included when decorated).
export struct WindowTile {
    id: int,
    title: string,
    texture: image,
    x: length,
    y: length,
    width: length,
    height: length,
    // Whether the compositor should draw a server-side title bar.
    decorated: bool,
    // Hidden from the content area (still listed in the sidebar to restore).
    minimized: bool,
    // The client has been told it is maximized.
    maximized: bool,
    // Whether this window currently holds keyboard focus (highlights its frame).
    focused: bool,
}

// A client popup (menu, dropdown, tooltip), positioned in the content area.
export struct PopupTile {
    id: int,
    texture: image,
    x: length,
    y: length,
    width: length,
    height: length,
}

// A wlr-layer-shell surface (panel, wallpaper, overlay), positioned in the
// whole window. `layer` is 0=background, 1=bottom, 2=top, 3=overlay.
export struct LayerTile {
    id: int,
    texture: image,
    layer: int,
    x: length,
    y: length,
    width: length,
    height: length,
}

// An on-screen notification toast (from the freedesktop notification daemon).
export struct NotificationToast {
    id: int,
    app: string,
    summary: string,
    body: string,
}

// A system-tray (StatusNotifierItem) icon.
export struct TrayIcon {
    id: string,
    title: string,
    icon: image,
}
