import { Theme } from "theme.slint";
import { AppData, Logic } from "globals.slint";
import { LineEdit, Button, ComboBox } from "std-widgets.slint";

// An editable filesystem-path field with a dropdown of previously entered paths.
component PathCombo inherits Rectangle {
    in property <[string]> history;
    in property <string> placeholder;
    in-out property <string> text <=> edit.text;
    height: 32px;

    HorizontalLayout {
        spacing: 4px;
        edit := LineEdit {
            horizontal-stretch: 1;
            placeholder-text: root.placeholder;
        }
        Button {
            width: 36px;
            text: "▾";
            clicked => { popup.show(); }
        }
    }

    popup := PopupWindow {
        x: 0;
        y: root.height + 2px;
        width: root.width;
        Rectangle {
            background: Theme.surface;
            border-radius: Theme.radius;
            border-width: 1px;
            border-color: Theme.surface-hover;
            VerticalLayout {
                padding: 4px;
                if root.history.length == 0: Text {
                    text: "No previous repos";
                    color: Theme.text-dim;
                    font-size: 12px;
                    horizontal-alignment: center;
                }
                for entry in root.history: TouchArea {
                    height: 28px;
                    clicked => {
                        edit.text = entry;
                        popup.close();
                    }
                    Rectangle {
                        background: parent.has-hover ? Theme.surface-hover : transparent;
                        border-radius: 4px;
                        HorizontalLayout {
                            padding-left: 6px;
                            Text {
                                text: entry;
                                color: Theme.text;
                                font-size: 12px;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                    }
                }
            }
        }
    }
}

// Modal wizard for creating a new task. Shown as a full-window overlay; the
// caller toggles `visible`.
export component Wizard inherits Rectangle {
    callback close();
    background: #000000aa;

    // Reset the fields each time the wizard appears.
    public function reset() {
        name-edit.text = "";
        branch-edit.text = "";
        repo-combo.text = "";
    }

    // Swallow clicks on the dim backdrop so they don't fall through to the
    // desktop; clicking outside the card cancels.
    backdrop := TouchArea {
        clicked => { root.close(); }
    }

    Rectangle {
        width: 420px;
        height: card.preferred-height + 2 * Theme.padding;
        background: Theme.bg;
        border-radius: 12px;
        border-width: 1px;
        border-color: Theme.surface;

        // Eat clicks on the card itself.
        TouchArea {}

        card := VerticalLayout {
            padding: 20px;
            spacing: 14px;

            Text {
                text: "New task";
                color: Theme.text;
                font-size: 20px;
                font-weight: 700;
            }

            VerticalLayout {
                spacing: 4px;
                Text { text: "Name"; color: Theme.text-dim; font-size: 12px; }
                name-edit := LineEdit {
                    placeholder-text: "What are you working on?";
                }
            }

            VerticalLayout {
                spacing: 4px;
                Text { text: "Category"; color: Theme.text-dim; font-size: 12px; }
                category-box := ComboBox {
                    model: AppData.categories;
                    current-index: 0;
                }
            }

            VerticalLayout {
                spacing: 4px;
                Text { text: "Branch (optional)"; color: Theme.text-dim; font-size: 12px; }
                branch-edit := LineEdit {
                    placeholder-text: "feature/my-branch";
                }
            }

            VerticalLayout {
                spacing: 4px;
                Text { text: "Origin repo path (optional)"; color: Theme.text-dim; font-size: 12px; }
                repo-combo := PathCombo {
                    history: AppData.repo-history;
                    placeholder: "~/projects/my-repo";
                }
            }

            HorizontalLayout {
                spacing: 10px;
                alignment: end;
                Button {
                    text: "Cancel";
                    clicked => { root.close(); }
                }
                Button {
                    text: "Create";
                    primary: true;
                    enabled: name-edit.text != "";
                    clicked => {
                        Logic.create-task(
                            name-edit.text,
                            category-box.current-value,
                            branch-edit.text,
                            repo-combo.text,
                        );
                        root.close();
                    }
                }
            }
        }
    }
}
