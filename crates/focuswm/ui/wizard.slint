import { Theme, Card } from "theme.slint";
import { AppData, Logic } from "globals.slint";
import { LineEdit, Button, ComboBox, ListView } from "std-widgets.slint";

// An editable filesystem-path field with a dropdown of previously entered paths.
component PathCombo inherits Rectangle {
    in property <[string]> history;
    in property <string> placeholder;
    in-out property <string> text <=> edit.text;
    height: 32px;

    HorizontalLayout {
        spacing: 4px;
        edit := LineEdit {
            horizontal-stretch: 1;
            placeholder-text: root.placeholder;
        }
        Button {
            width: 36px;
            text: "▾";
            clicked => { popup.show(); }
        }
    }

    popup := PopupWindow {
        x: 0;
        y: root.height + 2px;
        width: root.width;
        Rectangle {
            background: Theme.surface;
            border-radius: Theme.radius;
            border-width: 1px;
            border-color: Theme.surface-hover;
            VerticalLayout {
                padding: 4px;
                if root.history.length == 0: Text {
                    text: "No previous repos";
                    color: Theme.text-dim;
                    font-size: 12px;
                    horizontal-alignment: center;
                }
                for entry in root.history: TouchArea {
                    height: 28px;
                    clicked => {
                        edit.text = entry;
                        popup.close();
                    }
                    Rectangle {
                        background: parent.has-hover ? Theme.surface-hover : transparent;
                        border-radius: 4px;
                        HorizontalLayout {
                            padding-left: 6px;
                            Text {
                                text: entry;
                                color: Theme.text;
                                font-size: 12px;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                    }
                }
            }
        }
    }
}

// Modal wizard for creating a new task. Shown as a full-window overlay; the
// caller toggles `visible`.
export component Wizard inherits Rectangle {
    callback close();
    background: Theme.scrim;

    // Reset the fields each time the wizard appears.
    public function reset() {
        name-edit.text = "";
        branch-edit.text = "";
        repo-combo.text = "";
        issue-edit.text = "";
        // Clear any previously selected/searched issue.
        Logic.link-issue("", 0, "", "");
    }

    // Swallow clicks on the dim backdrop so they don't fall through to the
    // desktop; clicking outside the card cancels.
    backdrop := TouchArea {
        clicked => { root.close(); }
    }

    Card {
        width: 440px;
        height: card.preferred-height + 2 * Theme.sp-6;

        // Eat clicks on the card itself.
        TouchArea {}

        card := VerticalLayout {
            padding: Theme.sp-6;
            spacing: Theme.sp-4;

            Text {
                text: "New task";
                color: Theme.text;
                font-size: Theme.fs-title;
                font-weight: 700;
            }

            VerticalLayout {
                spacing: 4px;
                Text { text: "Name"; color: Theme.text-dim; font-size: 12px; }
                name-edit := LineEdit {
                    placeholder-text: "What are you working on?";
                }
            }

            VerticalLayout {
                spacing: 4px;
                Text { text: "Category"; color: Theme.text-dim; font-size: 12px; }
                category-box := ComboBox {
                    model: AppData.categories;
                    current-index: 0;
                }
            }

            VerticalLayout {
                spacing: 4px;
                Text { text: "Branch (optional)"; color: Theme.text-dim; font-size: 12px; }
                branch-edit := LineEdit {
                    placeholder-text: "feature/my-branch";
                }
            }

            VerticalLayout {
                spacing: 4px;
                Text { text: "Origin repo path (optional)"; color: Theme.text-dim; font-size: 12px; }
                repo-combo := PathCombo {
                    history: AppData.repo-history;
                    placeholder: "~/projects/my-repo";
                }
            }

            VerticalLayout {
                spacing: 4px;
                Text { text: "Link a GitHub issue / PR (optional)"; color: Theme.text-dim; font-size: 12px; }
                HorizontalLayout {
                    spacing: 4px;
                    issue-edit := LineEdit {
                        horizontal-stretch: 1;
                        enabled: AppData.github-enabled;
                        placeholder-text: AppData.github-enabled
                            ? "Search issues/PRs…"
                            : "Set GITHUB_TOKEN to enable";
                        accepted => { Logic.search-issues(self.text); }
                    }
                    Button {
                        text: AppData.issue-searching ? "…" : "Search";
                        enabled: AppData.github-enabled && issue-edit.text != "" && !AppData.issue-searching;
                        clicked => { Logic.search-issues(issue-edit.text); }
                    }
                }
                if AppData.issue-results.length > 0: Rectangle {
                    height: 132px;
                    border-radius: Theme.radius;
                    border-width: 1px;
                    border-color: Theme.surface-hover;
                    clip: true;
                    ListView {
                        for r in AppData.issue-results: ta := TouchArea {
                            height: 42px;
                            clicked => { Logic.link-issue(r.slug, r.number, r.title, r.url); }
                            Rectangle {
                                background: r.selected ? Theme.accent-soft
                                    : (ta.has-hover ? Theme.surface-hover : transparent);
                                VerticalLayout {
                                    padding-left: 8px;
                                    padding-right: 8px;
                                    Text {
                                        text: "#\{r.number}  \{r.title}";
                                        color: Theme.text;
                                        font-size: 12px;
                                        overflow: elide;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: r.slug;
                                        color: Theme.text-dim;
                                        font-size: 10px;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }
            }

            HorizontalLayout {
                spacing: 10px;
                alignment: end;
                Button {
                    text: "Cancel";
                    clicked => { root.close(); }
                }
                Button {
                    text: "Create";
                    primary: true;
                    enabled: name-edit.text != "";
                    clicked => {
                        Logic.create-task(
                            name-edit.text,
                            category-box.current-value,
                            branch-edit.text,
                            repo-combo.text,
                        );
                        root.close();
                    }
                }
            }
        }
    }
}
